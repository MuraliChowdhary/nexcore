generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String     @id @default(uuid())
  title       String
  description String
  techStack   String[]
  rolesNeeded String[]
  ownerId     String
  visibility  Visibility @default(PUBLIC)
  members     Member[]
  invites     Invite[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([visibility])
  @@index([ownerId])
  @@map("projects")
}

model Member {
  id        String     @id @default(uuid())
  userId    String
  projectId String
  role      MemberRole @default(COLLABORATOR)
  joinedAt  DateTime   @default(now())

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("members")
}

model Invite {
  id          String       @id @default(uuid())
  projectId   String
  inviteeId   String
  inviterId   String
  inviterName String
  status      InviteStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  expiresAt   DateTime

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, inviteeId])
  @@index([inviteeId, status])
  @@map("invites")
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum MemberRole {
  OWNER
  COLLABORATOR
  VIEWER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}